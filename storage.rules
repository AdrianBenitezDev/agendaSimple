rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function tenantDoc(tenantId) {
      return firestore.get(/databases/(default)/documents/tenants/$(tenantId)).data;
    }

    function tenantAdminDoc(tenantId) {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/tenants/$(tenantId)/admins/$(request.auth.uid)).data
        : null;
    }

    function activeTenantAdmin(tenantId) {
      let tenant = tenantDoc(tenantId);
      let admin = tenantAdminDoc(tenantId);

      return tenant != null
        && admin != null
        && tenant.active == true
        && tenant.adminEnabled == true
        && admin.active == true;
    }

    function tenantAdminManager(tenantId) {
      let tenant = tenantDoc(tenantId);
      let admin = tenantAdminDoc(tenantId);

      return tenant != null
        && admin != null
        && tenant.active == true
        && tenant.adminEnabled == true
        && admin.active == true
        && (
          admin.canManageAdminAccess == true
          || admin.membershipRole == "owner"
          || admin.membershipRole == "admin"
        );
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /tenants/{tenantId}/admins/{adminId}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if activeTenantAdmin(tenantId) && request.auth.uid == adminId;
    }

    match /tenants/{tenantId}/productos/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if activeTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/servicios/{serviceId}/{allPaths=**} {
      allow read: if true;
      allow write: if activeTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/salon/{salonMediaId}/{allPaths=**} {
      allow read: if true;
      allow write: if tenantAdminManager(tenantId);
    }

    match /admins/{adminId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
